{
  "name": "@videojs/ads",
  "type": "module",
  "version": "10.0.0-beta.11",
  "private": true,
  "description": "Ad framework for Video.js 10",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/dev/index.d.ts",
      "development": "./dist/dev/index.js",
      "default": "./dist/default/index.js"
    },
    "./dom": {
      "types": "./dist/dev/dom.d.ts",
      "development": "./dist/dev/dom.js",
      "default": "./dist/default/dom.js"
    },
    "./cdn/video-ads": {
      "development": "./cdn/video-ads.dev.js",
      "default": "./cdn/video-ads.js"
    },
    "./cdn/videojs-ads": {
      "development": "./cdn/videojs-ads.dev.js",
      "default": "./cdn/videojs-ads.js"
    }
  },
  "main": "dist/default/index.js",
  "module": "dist/default/index.js",
  "types": "dist/dev/index.d.ts",
  "files": [
    "dist",
    "cdn"
  ],
  "scripts": {
    "build": "tsdown",
    "build:cdn": "tsdown --config tsdown.cdn.config.ts",
    "build:watch": "tsdown --watch ./src --no-clean",
    "dev": "pnpm run build:watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf --glob dist cdn types '*.tsbuildinfo'"
  },
  "dependencies": {
    "@videojs/html": "workspace:*",
    "@videojs/utils": "workspace:*",
    "@videojs/store": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
